{{ if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env zsh

# Uncomment to profile startup
# zmodload zsh/zprof

{{ include "shell/init.zsh" }}

export ZSH_DOTFILES_VERSION_MANAGER={{ .version_manager | quote }}
export ZSH_DOTFILES_FZF_TAB={{ and (hasKey . "fzf_tab") .fzf_tab }}

{{  if or (lookPath "sheldon") (stat (joinPath .chezmoi.homeDir ".local" "bin" "sheldon")) -}}
# Source sheldon plugins (with runtime config check)
if [[ -f "$HOME/.sheldon/plugins.toml" ]]; then
    export PATH="$HOME/.local/bin:$PATH"
    eval "$(sheldon source)"
fi
{{  end -}}

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
{{ end -}}

