{{- if (eq .chezmoi.os "linux") -}}
{{- if (or (eq .chezmoi.osRelease.id "centos") (eq .chezmoi.osRelease.id "ol") (eq .chezmoi.osRelease.id "rhel")) -}}

#!/bin/sh

# Install deno on CentOS/RHEL/OL via official curl installer
# Requires: unzip

if [ ! -d "${HOME}/.deno" ]; then
    (
        set -x; printf "${yellow}[11 - deno does not exist, downloading] ${reset}" &&
        curl -fsSL https://deno.land/install.sh | sh
    )
fi

export DENO_INSTALL="$HOME/.deno"
export PATH="$DENO_INSTALL/bin:$PATH"

if [ -n "$(command -v deno 2>/dev/null)" ]; then
    deno --version
fi

{{ end -}}
{{ end -}}
