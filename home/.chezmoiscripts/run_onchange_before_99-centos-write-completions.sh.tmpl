{{- if (eq .chezmoi.os "linux") -}}
{{- if or (eq .chezmoi.osRelease.id "centos") (eq .chezmoi.osRelease.id "ol") (eq .chezmoi.osRelease.id "rhel") -}}
#!/usr/bin/env zsh

mkdir -p  $HOME/.zsh/completion || true
if [ -f ~/.bin/chezmoi ]; then
    ~/.bin/chezmoi completion zsh > ~/.zsh/completion/_chezmoi
elif [ -f ~/bin/chezmoi ]; then
    ~/bin/chezmoi completion zsh > ~/.zsh/completion/_chezmoi
fi
fpath+="$HOME/.zsh/completion"

if [ -n "$(command which bun 2>/dev/null)" ]; then
    bun completions > ~/.zsh/completion/_bun 2>/dev/null || true
    bun completions > ~/.zsh/completions/_bun 2>/dev/null || true
fi

if [ -n "$(command which deno 2>/dev/null)" ]; then
    deno completions zsh > ~/.zsh/completion/_deno 2>/dev/null || true
    deno completions zsh > ~/.zsh/completions/_deno 2>/dev/null || true
fi

{{ end -}}
{{ end -}}
