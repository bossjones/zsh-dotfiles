{{- if (eq .chezmoi.os "linux") -}}
{{- if (eq .chezmoi.osRelease.id "ubuntu") -}}

#!/bin/sh

# Install bun on Ubuntu via official curl installer
# Requires: unzip (should already be installed from prereqs)

if [ ! -d "${HOME}/.bun" ]; then
    (
        set -x; printf "${yellow}[11 - bun does not exist, downloading] ${reset}" &&
        curl -fsSL https://bun.com/install | bash
    )
fi

export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

if [ -n "$(command -v bun 2>/dev/null)" ]; then
    bun --version
fi

{{ end -}}
{{ end -}}
