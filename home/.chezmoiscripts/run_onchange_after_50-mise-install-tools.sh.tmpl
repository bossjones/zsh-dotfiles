{{- if eq .version_manager "mise" -}}
#!/bin/bash

{{ if eq .chezmoi.os "darwin" -}}
# NOTE: https://github.com/asdf-vm/asdf-ruby/issues/345 (compile ruby on arm64)
UNAME_MACHINE="$(/usr/bin/uname -m)"
if [ "$UNAME_MACHINE" = "arm64" ]
then
  # ruby needs this
  export RUBY_CONFIGURE_OPTS="--disable-install-doc --disable-shared --with-openssl-dir=$(brew --prefix openssl@3)"

  # tmux needs this
  export LDFLAGS="${LDFLAGS} -L${LOCAL_HOMEBREW_PREFIX}/opt/openssl@3/lib"
  export CPPFLAGS="${CPPFLAGS} -I${LOCAL_HOMEBREW_PREFIX}/opt/openssl@3/include"
  export PKG_CONFIG_PATH="${PKG_CONFIG_PATH} ${LOCAL_HOMEBREW_PREFIX}/opt/openssl@3/lib/pkgconfig"
fi
{{ end -}}

{{ if eq .chezmoi.os "linux" -}}
{{ if eq .chezmoi.osRelease.id "ubuntu" }}
sudo apt-get install autotools-dev automake unzip zip -y || true
sudo apt-get install libyaml-dev -y || true
{{ end }}
{{ if or (eq .chezmoi.osRelease.id "centos") (eq .chezmoi.osRelease.id "ol") (eq .chezmoi.osRelease.id "rhel") }}
sudo dnf install -y --allowerasing automake unzip zip || true
sudo dnf install -y libyaml-devel || true
{{ end }}
{{ end -}}

# Activate mise so the binary is on PATH for the rest of this script.
# mise is installed either at $HOME/.local/bin/mise (linux installer) or via brew (macOS).
export PATH="$HOME/.local/bin:$PATH"

printf "${green}[50 - mise] ${reset}"
{{- if or (lt 31 (atoi (env "SCRIPTS_START_AT"))) (env "SKIP_ASDF_PLUGINS") (env "SKIP_MISE_PLUGINS") }}
echo "Skip installing mise tools"
exit 0
{{ else }}
echo "Install mise tools"
{{- end }}

eval "$(mise activate bash)"

# Ruby 3.x is EOL/slow to compile from source on macOS 26 / arm64. Use mise's
# precompiled binaries instead of building from source (mise itself recommends
# this). Persist the setting, and also export the env var for this run.
mise settings set ruby.compile false || true
export MISE_RUBY_COMPILE=0

{{ $tools := dict
  "ruby"       (.myAsdfRubyVersion)
  "golang"     (.myAsdfGolangVersion)
  "asdf:mise-plugins/mise-tmux" (.myAsdfTmuxVersion)
  "neovim"     (.myAsdfNeovimVersion)
  "github-cli" (.myAsdfGithubCliVersion)
  "mkcert"     (.myAsdfMkcertVersion)
  "shellcheck" (.myAsdfShellcheckVersion)
  "shfmt"      (.myAsdfShfmtVersion)
  "yq"         (.myAsdfYqVersion)
  "helm"       (.myAsdfHelmVersion)
  "helmfile"   (.myAsdfHelmfileVersion)
  "helm-docs"  (.myAsdfHelmdocsVersion)
  "k9s"        (.myAsdfK9sVersion)
  "kubectx"    (.myAsdfKubectxVersion)
  "opa"        (.myAsdfOpaVersion)
  "kubectl"    (.myAsdfKubectlVersion)
  "aqua:johanhaleby/kubetail" (.myAsdfKubetailVersion)
}}

# Install + globally pin each tool. mise's built-in registry covers every
# tool above, so no custom plugin URLs are needed (unlike the asdf path).
{{ range (keys $tools) -}}
  {{- $key := . }}
  {{- $val := get $tools $key }}
  {{- if not (eq $val "None") }}
    mise use -g {{ $key }}@{{ $val }} || true
  {{- end -}}
{{ end }}

# -- Ruby gem packages -- #

{{ $rubyPackages := list
  "foreman"
  "tmuxinator"
}}

{{ range sortAlpha $rubyPackages }}
  mise exec ruby@{{ $.myAsdfRubyVersion }} -- gem install {{ . }} --no-doc || true
{{ end -}}

mise reshim || true

{{ end -}}
