{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "true"
  },
  "permissions": {
    "allow": [
      "Bash(awk:*)",
      "Bash(base64:*)",
      "Bash(basename:*)",
      "Bash(bash -n:*)",
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(date:*)",
      "Bash(diff:*)",
      "Bash(dirname:*)",
      "Bash(docker compose build:*)",
      "Bash(echo:*)",
      "Bash(file:*)",
      "Bash(find:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh release list:*)",
      "Bash(gh release view:*)",
      "Bash(gh repo view:*)",
      "Bash(git add:*)",
      "Bash(git blame:*)",
      "Bash(git branch:*)",
      "Bash(git commit:*)",
      "Bash(git config --list:*)",
      "Bash(git describe:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git ls-files:*)",
      "Bash(git ls-tree:*)",
      "Bash(git push:*)",
      "Bash(git remote -v:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(git tag -l:*)",
      "Bash(git worktree list:*)",
      "Bash(go doc:*)",
      "Bash(go env:*)",
      "Bash(go list:*)",
      "Bash(go version:*)",
      "Bash(go vet:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(hostname:*)",
      "Bash(id:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(make smoke:*)",
      "Bash(md5sum:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(npm:*)",
      "Bash(pre-commit run:*)",
      "Bash(pwd:*)",
      "Bash(realpath:*)",
      "Bash(rg:*)",
      "Bash(shasum:*)",
      "Bash(shellcheck:*)",
      "Bash(sort:*)",
      "Bash(stat:*)",
      "Bash(tail:*)",
      "Bash(touch:*)",
      "Bash(tree:*)",
      "Bash(type:*)",
      "Bash(uname:*)",
      "Bash(uniq:*)",
      "Bash(uv:*)",
      "Bash(uvx pre-commit run:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(whoami:*)",
      "Edit",
      "mcp__firecrawl-mcp__firecrawl_scrape",
      "WebFetch",
      "WebFetch(domain:docs.mermaidchart.com)",
      "WebFetch(domain:job-boards.greenhouse.io)",
      "WebFetch(domain:www.perplexity.ai)",
      "WebSearch",
      "Write"
    ],
    "deny": []
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "ElevenLabs",
    "firecrawl-mcp",
    "perplexity-ask"
  ],
  "enabledPlugins": {
    "meta-claude@lunar-claude": true,
    "python-tools@lunar-claude": true,
    "hookify@lunar-claude": true,
    "documentation-generation@claude-code-workflows": true,
    "observability-monitoring@claude-code-workflows": true
  }
}
